# Copy this file on the Hostinger VPS:
# cp .env.hostinger.example .env.hostinger
# Then fill the real values. Do not commit .env.hostinger.

NEXT_PUBLIC_SUPABASE_URL=https://hzogvzxajqhrzazuapzz.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PROJECT_ID=hzogvzxajqhrzazuapzz

# Use the final Hostinger domain or subdomain.
# Example: https://kpi.deine-domain.de
NEXT_PUBLIC_SITE_URL=

# Server-only keys. Keep private.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Optional: if empty, TS KPI uses the primary/first active shop for daily briefing.
DAILY_BRIEFING_SHOP_ID=

# Optional ChatGPT API integration. Keep server-only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_AI_DISABLED=false

# Existing n8n is not changed by deployment.
# Only set these if your existing n8n workflows already have webhook URLs ready.
N8N_DAILY_WEBHOOK_URL=
N8N_DAILY_WEBHOOK_SECRET=
N8N_NOTIFICATION_WEBHOOK_URL=
N8N_NOTIFICATION_WEBHOOK_SECRET=
N8N_NOTIFICATION_RECIPIENT_EMAIL=finn-ole.bierlich@telekom.de
