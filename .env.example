# Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://hzogvzxajqhrzazuapzz.supabase.co

# Supabase Dashboard -> Project Settings -> API -> Project API keys -> publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional compatibility alias. Use the same value as NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL used for Supabase email confirmation and magic links.
# Local: http://localhost:3000
# Production: use your stable Vercel or custom domain.
NEXT_PUBLIC_SITE_URL=

# Optional. Project ref from the Supabase URL.
SUPABASE_PROJECT_ID=hzogvzxajqhrzazuapzz

# Server-only. Needed for /api/briefing/daily because Vercel Cron has no user session.
# Never expose this as NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional protection for Vercel Cron/manual calls.
CRON_SECRET=

# Optional: if empty, the primary/first active shop is used.
DAILY_BRIEFING_SHOP_ID=

# Optional ChatGPT API integration. Server-only. Never expose as NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_AI_DISABLED=false

# n8n webhook for daily mobile updates.
N8N_DAILY_WEBHOOK_URL=
N8N_DAILY_WEBHOOK_SECRET=

# n8n webhook for immediate registrations and 15-minute KPI digests.
# n8n can use /api/notifications/digest every 15 minutes and then send Gmail.
N8N_NOTIFICATION_WEBHOOK_URL=
N8N_NOTIFICATION_WEBHOOK_SECRET=
N8N_NOTIFICATION_RECIPIENT_EMAIL=finn-ole.bierlich@telekom.de
